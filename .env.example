# 任一 OpenAI 兼容端点均可。默认 DeepSeek。
# 也可只设 DEEPSEEK_API_KEY 或 OPENAI_API_KEY（查找顺序：GEWU_API_KEY > DEEPSEEK_API_KEY > OPENAI_API_KEY）
GEWU_API_KEY=sk-xxxx
GEWU_BASE_URL=https://api.deepseek.com
GEWU_MODEL=deepseek-chat

# 可选
# GEWU_TEMPERATURE=0.3
# GEWU_CACHE_DIR=~/.gewu/cache
# GEWU_CACHE_MAX_AGE_DAYS=1     # 数据缓存过期天数
# GEWU_REQUEST_INTERVAL=1.0     # 数据源请求间隔（秒），保护免费接口
# GEWU_DEBATE_ROUNDS=2          # 多空辩论轮数
